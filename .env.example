# Copy to .env and edit for your environment.
# `docker compose` reads .env automatically.

# HuggingFace token — required for gated repos (e.g. some Black Forest Labs / Lightricks)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Web UI port on the host
COMFYUI_PORT=8188

# Build parallelism — DGX Spark has 20 perf cores, 20 is a sane max
BUILD_JOBS=20

# Skip auto-downloading the bundled model set on first start (set to 1 to skip)
SKIP_MODEL_DOWNLOAD=0

# Skip the optional huihui-ai abliterated full LLM snapshots (~70GB combined)
SKIP_ABLITERATED=0

# Force re-download even if the sentinel exists
FORCE_MODEL_DOWNLOAD=0
