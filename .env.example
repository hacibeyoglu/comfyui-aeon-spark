# Copy to .env and edit, OR run ./setup.sh which generates this for you.
# `docker compose` reads .env automatically.

# Image variant on GHCR.
#   latest = code + auto-downloader (pulls ~285 GB on first start using HF_TOKEN)
#   slim   = code only, no auto-download (you install each model via the UI)
IMAGE_TAG=latest

# HuggingFace token — REQUIRED for `latest`, optional for `slim`.
# Get one at https://huggingface.co/settings/tokens (Read scope is enough).
# Plus accept the gated BFL repos: FLUX.2-dev, FLUX.2-klein-base-9b-fp8,
# FLUX.2-small-decoder (one-time click on each model page).
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Web UI port on the host
COMFYUI_PORT=8188

# Skip auto-downloading the bundled model set on first start (set to 1 to skip)
# (this is implicit on `slim` — already SKIP_MODEL_DOWNLOAD=1 baked in)
SKIP_MODEL_DOWNLOAD=0

# Skip the optional huihui-ai abliterated full LLM snapshots (~70 GB combined)
SKIP_ABLITERATED=0

# Force re-download even if the .models_seeded sentinel exists
FORCE_MODEL_DOWNLOAD=0

# Override Ollama's preloaded prompt-expansion model (default gemma3:4b)
# OLLAMA_PRELOAD_MODEL=llama3.2:3b
