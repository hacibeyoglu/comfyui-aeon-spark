# syntax=docker/dockerfile:1.7
# =============================================================================
# Full bake — extends the slim image with all 22 model files needed by the 8
# pre-seeded workflows pre-staged at /opt/baked_models/.  The entrypoint adds
# an extra_model_paths.yaml entry so ComfyUI's loaders see them on first start.
#
# Layer strategy: ONE LAYER PER FILE. Earlier attempts with per-subdir COPY
# produced single layers >100 GB which GHCR/Azure-Blob-Storage struggled to
# accept (push hung with zero bytes uploaded for 70+ min). Per-file layers
# stay ≤46 GB (the largest single file) and push reliably.
# =============================================================================

FROM ghcr.io/aeon-7/comfyui-aeon-spark:bf16-flux2-ltx2.3 AS full

# ---- VAEs (3 files, ~700 MB total — fast cache warmer) ----
COPY baked_models/vae/flux2-vae.safetensors                                         /opt/baked_models/vae/
COPY baked_models/vae/full_encoder_small_decoder.safetensors                        /opt/baked_models/vae/
COPY baked_models/vae/ace_1.5_vae.safetensors                                       /opt/baked_models/vae/

# ---- Latent upscalers (2 files, ~1.2 GB) ----
COPY baked_models/latent_upscale_models/ltx-2.3-spatial-upscaler-x2-1.1.safetensors /opt/baked_models/latent_upscale_models/
COPY baked_models/latent_upscale_models/ltx-2.3-temporal-upscaler-x2-1.0.safetensors /opt/baked_models/latent_upscale_models/

# ---- LoRAs (6 files, ~21 GB) ----
COPY baked_models/loras/Flux_2-Turbo-LoRA_comfyui.safetensors                       /opt/baked_models/loras/
COPY baked_models/loras/ltx-2.3-id-lora-talkvid-3k.safetensors                      /opt/baked_models/loras/
COPY baked_models/loras/gemma-3-12b-it-abliterated_lora_rank64_bf16.safetensors     /opt/baked_models/loras/
COPY baked_models/loras/gemma-3-12b-it-abliterated_heretic_lora_rank64_bf16.safetensors /opt/baked_models/loras/
COPY baked_models/loras/ltx-2.3-22b-distilled-lora-384.safetensors                  /opt/baked_models/loras/
COPY baked_models/loras/ltxv/ltx2/ltx-2.3-22b-distilled-lora-384-1.1.safetensors    /opt/baked_models/loras/ltxv/ltx2/

# ---- Smaller text encoders (4 files, ~28 GB) ----
COPY baked_models/text_encoders/qwen_0.6b_ace15.safetensors                         /opt/baked_models/text_encoders/
COPY baked_models/text_encoders/qwen_4b_ace15.safetensors                           /opt/baked_models/text_encoders/
COPY baked_models/text_encoders/qwen_3_8b_fp8mixed.safetensors                      /opt/baked_models/text_encoders/
COPY baked_models/text_encoders/gemma_3_12B_it_fp4_mixed.safetensors                /opt/baked_models/text_encoders/

# ---- ACE-Step DiT (10 GB) ----
COPY baked_models/diffusion_models/acestep_v1.5_xl_turbo_bf16.safetensors           /opt/baked_models/diffusion_models/

# ---- BIG files (each ≥24 GB, each its own layer for reliable upload) ----
COPY baked_models/text_encoders/comfy_gemma_3_12B_it.safetensors                    /opt/baked_models/text_encoders/
COPY baked_models/diffusion_models/flux2_dev_fp8mixed.safetensors                   /opt/baked_models/diffusion_models/
COPY baked_models/text_encoders/mistral_3_small_flux2_bf16.safetensors              /opt/baked_models/text_encoders/
COPY baked_models/checkpoints/ltx-2.3-22b-distilled-fp8.safetensors                 /opt/baked_models/checkpoints/
COPY baked_models/checkpoints/ltx-2.3-22b-dev-fp8.safetensors                       /opt/baked_models/checkpoints/
COPY baked_models/checkpoints/ltx-2.3-22b-dev.safetensors                           /opt/baked_models/checkpoints/

# Tell the entrypoint to wire baked models into ComfyUI's loaders
ENV BAKED_MODELS=/opt/baked_models

LABEL org.opencontainers.image.title="ComfyUI · AEON DGX Spark · Flux 2 + LTX 2.3 + ACE-Step (BF16, FULL — models pre-baked)" \
      org.opencontainers.image.description="Fully self-contained variant of comfyui-aeon-spark with ~243 GB of model weights pre-baked into the image. No first-start download. Works offline / air-gapped after pull. ComfyUI optimized for DGX Spark (GB10 / sm_121a) with CUDA 13 + SageAttention v3 (compiled for sm_121a) + NVFP4 (CUTLASS) hardware path." \
      org.opencontainers.image.source="https://github.com/AEON-7/comfyui-aeon-spark" \
      org.opencontainers.image.documentation="https://github.com/AEON-7/comfyui-aeon-spark/blob/main/README.md" \
      org.opencontainers.image.version="bf16-flux2-ltx2.3-full" \
      io.aeon.dgx-spark.bake="true" \
      io.aeon.dgx-spark.baked-size-gb="243" \
      io.aeon.dgx-spark.baked-files="22" \
      io.aeon.dgx-spark.layer-strategy="one-per-file (max ~46 GB per layer for GHCR reliability)" \
      io.aeon.dgx-spark.notes="Klein-9B base FP8 omitted (BFL gated repo); accept license at huggingface.co/black-forest-labs/FLUX.2-klein-base-9b-fp8 then download manually if needed for workflow 08."
